{
    "name": "mi-proyecto",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
      "backend",
      "frontend"
    ],
    "scripts": {
      "start:backend": "npm --prefix backend run dev",
      "start:frontend": "npm --prefix frontend run dev",
      "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\""
    },
    "devDependencies": {
      "concurrently": "^8.0.1"
    }
  }
  